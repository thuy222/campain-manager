{
  "name": "campaign-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Mini Campaign Manager — full-stack monorepo (Express + React 18)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta \"yarn workspace @campaign-manager/backend dev\" \"yarn workspace @campaign-manager/frontend dev\"",
    "dev:backend": "yarn workspace @campaign-manager/backend dev",
    "dev:frontend": "yarn workspace @campaign-manager/frontend dev",
    "build": "yarn workspaces run build",
    "start": "yarn workspace @campaign-manager/backend start",
    "test": "yarn workspaces run test",
    "db:migrate": "yarn workspace @campaign-manager/backend db:migrate",
    "db:rollback": "yarn workspace @campaign-manager/backend db:rollback",
    "db:seed": "yarn workspace @campaign-manager/backend db:seed",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/*/build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
